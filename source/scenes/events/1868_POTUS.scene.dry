title: 1868 Presidential Election
subtitle: [+ Candidate +] vs. Seymour[? if liberal_split = 1 : vs. Greeley ?]
tags: event
view-if: year = 1868 and month = 11
max-visits: 1

= Elections, [+ month +] [+ year +]

The Presidential election are to be held now.

[? if liberal_split = 1 : The Liberal Republicans have fielded their own candidate, threatening to split the anti-Democrat vote. ?]

- @POTUS_election_algorithm: May we do our best...

@POTUS_election_algorithm
on-arrival:{!
// Reset EV totals
Q.repEVTotal = 0;
Q.demEVTotal = 0;
Q.libEVTotal = 0;

// Define close states with target margin in percent (Republican margin)
let closeStates = {
  "CA": 0.48,
  "OR": -0.74,
  "NY": -1.18,
  "NJ": -1.76,
  "AL": 2.50,
  "IN": 2.79,
  "CT": 2.98,
  "PA": 4.41,
  "NC": 6.82,
  "AR": 7.37,
  "OH": 8.01
};

function randomNoise() {
  const sign = Math.random() < 0.5 ? -1 : 1;
  return sign * (Math.random() * 0.1 + 0.05);
}

// Run election per state
for (let state of Q.states) {
  let votes = { rep: 0, dem: 0, lib: 0 };

  for (let cls of Q.classes) {

    if (cls === "freemen" && Q.fifthteen == 0){
      // skip freemen if 15th amendment not passed
    }
    else {
      let pop = Q[state + "_" + cls] || 0;

      let raw = {
        rep: Q[state + "_" + cls + "_rep"] || 0,
        dem: Q[state + "_" + cls + "_dem"] || 0,
        lib: Q[state + "_" + cls + "_lib"] || 0
      };

      let mod = {
        rep: Q[cls + "_rep"] || 0,
        dem: Q[cls + "_dem"] || 0,
        lib: Q[cls + "_lib"] || 0
      };

      let adj = {
        rep: 0.2 * raw.rep + 0.8 * mod.rep,
        dem: 0.2 * raw.dem + 0.8 * mod.dem,
        lib: Q.liberal_split ? (0.2 * raw.lib + 0.8 * mod.lib) : 0
      };

      let total = adj.rep + adj.dem + adj.lib;
      if (!total) continue;

      adj.rep = Math.min(100, Math.max(0, adj.rep * (1 + randomNoise())));
      adj.dem = Math.min(100, Math.max(0, adj.dem * (1 + randomNoise())));
      if (Q.liberal_split) {
        adj.lib = Math.min(100, Math.max(0, adj.lib * (1 + randomNoise())));
      }

      total = adj.rep + adj.dem + adj.lib;

      votes.rep += pop * adj.rep / total;
      votes.dem += pop * adj.dem / total;
      if (Q.liberal_split) {
        votes.lib += pop * adj.lib / total;
      }
    }
  }

  // Apply close state adjustment with randomness
  // Only adjust rep vs dem margin; lib votes stay as calculated
  if (closeStates[state] !== undefined) {
    let baseTarget = closeStates[state];
    let randomJitter = (Math.random() * 0.6) - 0.3;
    let marginTarget = baseTarget + randomJitter;

    let twoPartyTotal = votes.rep + votes.dem;
    if (twoPartyTotal > 0) {
      let currentMargin = ((votes.rep - votes.dem) / twoPartyTotal) * 100;
      let marginDiff = marginTarget - currentMargin;

      votes.rep += twoPartyTotal * (marginDiff / 200);
      votes.dem -= twoPartyTotal * (marginDiff / 200);

      votes.rep = Math.max(0, votes.rep);
      votes.dem = Math.max(0, votes.dem);
    }
  }

  // Determine state winner
  let winner = "rep";
  if (votes.dem >= votes.rep && votes.dem >= votes.lib) winner = "dem";
  if (Q.liberal_split && votes.lib >= votes.rep && votes.lib >= votes.dem) winner = "lib";

  Q[state + "_winner"] = winner;

  let color = "#d73027"; // rep default
  if (winner === "dem") color = "#4575b4";
  if (winner === "lib") color = "#DAA520";
  Q[state.toLowerCase() + "_winner_color"] = color;

  let margin = votes.rep - votes.dem;
  let marginPct = ((Math.abs(margin) / (votes.rep + votes.dem + votes.lib)) * 100).toFixed(2);

  console.log(
    `${state} winner: ${winner}, votes: rep=${votes.rep.toFixed(0)}, dem=${votes.dem.toFixed(0)}, lib=${votes.lib.toFixed(0)}, margin=${margin.toFixed(0)} (${marginPct}%)`
  );
}

// Allocate EVs
for (let state of Q.states) {
  let ev = Q[state + "_EV_" + Q.year];
  if (!ev) continue;

  let w = Q[state + "_winner"];
  if (w === "rep") Q.repEVTotal += ev;
  else if (w === "dem") Q.demEVTotal += ev;
  else if (w === "lib") Q.libEVTotal += ev;
}

// POTUS winner — needs majority of all EVs
let totalEV = Q.repEVTotal + Q.demEVTotal + Q.libEVTotal;
let majority = Math.floor(totalEV / 2) + 1;

if (Q.repEVTotal >= majority) {
  Q.potus_winner = "rep";
} else if (Q.demEVTotal >= majority) {
  Q.potus_winner = "dem";
} else if (Q.libEVTotal >= majority) {
  Q.potus_winner = "lib";
} else {
  // No majority — goes to House of Representatives
  Q.potus_winner = "house";
}

console.log(`EV totals: REP=${Q.repEVTotal}, DEM=${Q.demEVTotal}, LIB=${Q.libEVTotal}`);
console.log(`POTUS winner: ${Q.potus_winner}`);

!}
on-display: {!
  var winners = {
    al: Q.al_winner_color,
    ar: Q.ar_winner_color,
    ca: Q.ca_winner_color,
    co: Q.co_winner_color,
    ct: Q.ct_winner_color,
    de: Q.de_winner_color,
    fl: Q.fl_winner_color,
    ga: Q.ga_winner_color,
    il: Q.il_winner_color,
    in: Q.in_winner_color,
    ia: Q.ia_winner_color,
    ks: Q.ks_winner_color,
    ky: Q.ky_winner_color,
    la: Q.la_winner_color,
    me: Q.me_winner_color,
    md: Q.md_winner_color,
    ma: Q.ma_winner_color,
    mi: Q.mi_winner_color,
    mn: Q.mn_winner_color,
    ms: Q.ms_winner_color,
    mo: Q.mo_winner_color,
    ne: Q.ne_winner_color,
    nv: Q.nv_winner_color,
    nh: Q.nh_winner_color,
    nj: Q.nj_winner_color,
    ny: Q.ny_winner_color,
    nc: Q.nc_winner_color,
    oh: Q.oh_winner_color,
    or: Q.or_winner_color,
    pa: Q.pa_winner_color,
    ri: Q.ri_winner_color,
    sc: Q.sc_winner_color,
    tn: Q.tn_winner_color,
    tx: Q.tx_winner_color,
    vt: Q.vt_winner_color,
    va: Q.va_winner_color,
    wv: Q.wv_winner_color,
    wi: Q.wi_winner_color,
    dc: Q.dc_winner_color,
  };

  function drawMap() {
    ElectoralMap.draw({ container: "#electoral-map", winners: winners });
  }

  if (typeof ElectoralMap !== 'undefined') {
    drawMap();
  } else {
    var script = document.createElement('script');
    script.src = 'electoral-map.js';
    script.onload = drawMap;
    document.head.appendChild(script);
  }
!}
go-to: potus_menu


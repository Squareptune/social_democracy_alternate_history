title: 1872 Presidential Election
subtitle: [+ Candidate +] vs. [+ dem_candidate_1872 +][? if liberal_split = 1 and greeley_fusion = 0 : vs. Greeley ?]
tags: event
view-if: year = 1872 and month = 11
max-visits: 1

= Elections, [+ month +] [+ year +]

The Presidential election is to be held now.

[? if greeley_fusion = 1 : The Democrats have endorsed the Liberal Republican ticket of Greeley and Brown, uniting the opposition behind a single anti-Grant candidate. ?]
[? if liberal_split = 1 and greeley_fusion = 0 : The Liberal Republicans have fielded Greeley independently while the Democrats run their own candidate, splitting the opposition vote. ?]
[? if liberal_split = 0 : The Democrats are running their own candidate against the Republicans in a straight two-party contest. ?]

- @POTUS_election_algorithm_1872: May we do our best...

@POTUS_election_algorithm_1872
on-arrival:{!
Q.repEVTotal = 0;
Q.demEVTotal = 0;
Q.libEVTotal = 0;

// Historical 1872 margins (Republican margin in percentage points)
// Greeley ran as both Liberal Republican and Democrat in real history
let closeStates = {
  "VT":  78.97,
  "MA":  69.30,
  "RI":  71.97,
  "KS":  66.88,
  "NE":  63.51,
  "ME":  60.39,
  "NH":  52.56,
  "MN":  60.05,
  "MI":  62.70,
  "IA":  59.80,
  "IL":  56.30,
  "WI":  54.00,
  "OH":  53.23,
  "IN":  53.41,
  "PA":  63.14,
  "NV":  56.21,
  "CA":  56.38,
  "OR":  58.84,
  "CT":  52.63,
  "NJ":  54.03,
  "NY":  53.00,
  "WV":  56.67,
  "NC":  -0.87,
  "TN":  -9.46,
  "AL":  -3.67,
  "SC":  75.72,
  "MS":  63.07,
  "FL":  53.53,
  "AR":  -0.14,
  "LA":  -0.62,
  "VA":  -8.83,
  "GA":  -28.06,
  "KY":  -34.66,
  "MD":  -38.00,
  "DE":  -29.00,
  "MO":  -35.00,
  "TX":  -26.00
};

// If Greeley fusion occurred, the combined Dem+Lib vote is much stronger
// so we tighten all margins significantly
let fusionModifier = Q.greeley_fusion ? 0.5 : 1.0;

// National swing calculation
let baselineRep = 55;
let baselineDem = 42;
let nationalRepSwing = (Q.workers_rep + Q.middle_class_rep + Q.rural_rep + Q.freemen_rep + Q.immigrant_laborers_rep + Q.unemployed_rep) / 6 - baselineRep;
let nationalDemSwing = (Q.workers_dem + Q.middle_class_dem + Q.rural_dem + Q.freemen_dem + Q.immigrant_laborers_dem + Q.unemployed_dem) / 6 - baselineDem;

// If fusion occurred, dem and lib vote combine against republicans
// We need to track the fusion candidate separately
let fusionCandidate = Q.greeley_fusion ? "lib" : "dem";

for (let state of Q.states) {
  let votes = { rep: 0, dem: 0, lib: 0 };

  for (let cls of Q.classes) {
    if (cls === "freemen" && Q.fifthteen == 0) continue;

    let pop = Q[state + "_" + cls] || 0;

    if (cls === "freemen") {
      let suppressionRate = Math.min((Q.ViolencePenalty || 0) / 30, 1);
      pop = pop * (1 - suppressionRate);
    }

    if (pop <= 0) continue;

    let localRep = Q[state + "_" + cls + "_rep"] || 0;
    let localDem = Q[state + "_" + cls + "_dem"] || 0;
    let localLib = Q[state + "_" + cls + "_lib"] || 0;
    let nationalRep = Q[cls + "_rep"] || 0;
    let nationalDem = Q[cls + "_dem"] || 0;
    let nationalLib = Q[cls + "_lib"] || 0;

    let adjRep = 0.5 * localRep + 0.5 * nationalRep;
    let adjDem = 0.5 * localDem + 0.5 * nationalDem;
    let adjLib = Q.liberal_split ? (0.5 * localLib + 0.5 * nationalLib) : 0;

    // Apply national swing
    adjRep = Math.max(0, adjRep + nationalRepSwing * 0.3);
    adjDem = Math.max(0, adjDem + nationalDemSwing * 0.3);

    // If fusion occurred, Democratic voters fold into the Greeley/lib vote
    // Irish Democrats and old guard are reluctant — only 70% transfer
    if (Q.greeley_fusion) {
      adjLib += adjDem * 0.70;
      adjDem = adjDem * 0.30; // residual protest vote / abstentions modeled as reduced dem
    }

    // If Hancock or another strong Dem is running independently alongside Greeley,
    // split the opposition more severely
    if (Q.liberal_split && !Q.greeley_fusion) {
      // Greeley and Dem candidate split the anti-Rep vote
      // Lib gets reform-minded voters, Dem gets loyalists
      adjLib = adjLib * 1.2;
      adjDem = adjDem * 0.85;
    }

    // RNG noise before normalizing
    adjRep *= (0.92 + Math.random() * 0.16);
    adjDem *= (0.92 + Math.random() * 0.16);
    if (Q.liberal_split || Q.greeley_fusion) adjLib *= (0.92 + Math.random() * 0.16);

    let total = adjRep + adjDem + adjLib;
    if (!total) continue;

    votes.rep += pop * (adjRep / total);
    votes.dem += pop * (adjDem / total);
    if (Q.liberal_split || Q.greeley_fusion) votes.lib += pop * (adjLib / total);
  }

  // Close state nudge, weakened by fusion modifier
  if (closeStates[state] !== undefined) {
    let nudge = closeStates[state] * 0.3 * fusionModifier;
    let randomJitter = (Math.random() * 0.8) - 0.4;
    let marginTarget = nudge + randomJitter;

    let twoPartyTotal = votes.rep + votes.dem + votes.lib;
    let oppTotal = votes.dem + votes.lib; // combined opposition
    if (twoPartyTotal > 0) {
      let currentMargin = ((votes.rep - oppTotal) / twoPartyTotal) * 100;
      let marginDiff = marginTarget - currentMargin;

      votes.rep += twoPartyTotal * (marginDiff / 200);
      if (Q.greeley_fusion) {
        votes.lib -= twoPartyTotal * (marginDiff / 200);
      } else {
        votes.dem -= twoPartyTotal * (marginDiff / 200);
      }

      votes.rep = Math.max(0, votes.rep);
      votes.dem = Math.max(0, votes.dem);
      votes.lib = Math.max(0, votes.lib);
    }
  }

  // Determine state winner
  let winner = "rep";
  if (Q.greeley_fusion) {
    // Fusion: lib is the main opposition candidate
    if (votes.lib >= votes.rep) winner = "lib";
  } else if (Q.liberal_split) {
    // Three-way race
    if (votes.dem >= votes.rep && votes.dem >= votes.lib) winner = "dem";
    if (votes.lib >= votes.rep && votes.lib >= votes.dem) winner = "lib";
  } else {
    // Straight two-party
    if (votes.dem >= votes.rep) winner = "dem";
  }

  Q[state + "_winner"] = winner;

  let color = "#d73027";
  if (winner === "dem") color = "#4575b4";
  if (winner === "lib") color = "#DAA520";
  Q[state.toLowerCase() + "_winner_color"] = color;

  let margin = votes.rep - (votes.dem + votes.lib);
  let marginPct = ((Math.abs(margin) / (votes.rep + votes.dem + (votes.lib || 0))) * 100).toFixed(2);
  console.log(`${state} winner: ${winner}, rep=${votes.rep.toFixed(0)}, dem=${votes.dem.toFixed(0)}, lib=${votes.lib.toFixed(0)}, margin=${marginPct}%`);
}

// Allocate EVs
for (let state of Q.states) {
  let ev = Q[state + "_EV_" + Q.year];
  if (!ev) continue;

  let w = Q[state + "_winner"];
  if (w === "rep") Q.repEVTotal += ev;
  else if (w === "dem") Q.demEVTotal += ev;
  else if (w === "lib") Q.libEVTotal += ev;
}

let totalEV = Q.repEVTotal + Q.demEVTotal + Q.libEVTotal;
let majority = Math.floor(totalEV / 2) + 1;

if (Q.repEVTotal >= majority) Q.potus_winner = "rep";
else if (Q.demEVTotal >= majority) Q.potus_winner = "dem";
else if (Q.libEVTotal >= majority) Q.potus_winner = "lib";
else Q.potus_winner = "house";

console.log(`EV totals: REP=${Q.repEVTotal}, DEM=${Q.demEVTotal}, LIB=${Q.libEVTotal}`);
console.log(`POTUS winner: ${Q.potus_winner}`);
!}
on-display: {!
  var winners = {
    al: Q.al_winner_color,
    ar: Q.ar_winner_color,
    ca: Q.ca_winner_color,
    co: Q.co_winner_color,
    ct: Q.ct_winner_color,
    de: Q.de_winner_color,
    fl: Q.fl_winner_color,
    ga: Q.ga_winner_color,
    il: Q.il_winner_color,
    in: Q.in_winner_color,
    ia: Q.ia_winner_color,
    ks: Q.ks_winner_color,
    ky: Q.ky_winner_color,
    la: Q.la_winner_color,
    me: Q.me_winner_color,
    md: Q.md_winner_color,
    ma: Q.ma_winner_color,
    mi: Q.mi_winner_color,
    mn: Q.mn_winner_color,
    ms: Q.ms_winner_color,
    mo: Q.mo_winner_color,
    ne: Q.ne_winner_color,
    nv: Q.nv_winner_color,
    nh: Q.nh_winner_color,
    nj: Q.nj_winner_color,
    ny: Q.ny_winner_color,
    nc: Q.nc_winner_color,
    oh: Q.oh_winner_color,
    or: Q.or_winner_color,
    pa: Q.pa_winner_color,
    ri: Q.ri_winner_color,
    sc: Q.sc_winner_color,
    tn: Q.tn_winner_color,
    tx: Q.tx_winner_color,
    vt: Q.vt_winner_color,
    va: Q.va_winner_color,
    wv: Q.wv_winner_color,
    wi: Q.wi_winner_color,
    dc: Q.dc_winner_color,
  };

  function drawMap() {
    ElectoralMap.draw({ container: "#electoral-map", winners: winners });
  }

  if (typeof ElectoralMap !== 'undefined') {
    drawMap();
  } else {
    var script = document.createElement('script');
    script.src = 'electoral-map.js';
    script.onload = drawMap;
    document.head.appendChild(script);
  }
!}
go-to: potus_menu_1872

